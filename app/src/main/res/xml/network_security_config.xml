<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext only for debug builds (localhost) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Debug override for local development -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

    <!--
        Certificate pinning is handled by OkHttp CertificatePinner (in NetworkModule)
        when BuildConfig.CERT_PINNING_ENABLED is true.
        Placeholder pins in XML cause crashes on some Android versions,
        so pinning is done at the HTTP client level instead.
    -->
</network-security-config>
